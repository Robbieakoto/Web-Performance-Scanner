# ─────────────────────────────────────────────────────────────
# Ghana Web Performance Scanner — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# Google PageSpeed Insights API Key
# Get one at: https://developers.google.com/speed/docs/insights/v5/get-started
PSI_API_KEY=your_pagespeed_insights_api_key_here

# Firebase Project ID
# Find it in: https://console.firebase.google.com → Project Settings
FIREBASE_PROJECT_ID=your_firebase_project_id_here
